# AuraScribe — copy to .env and fill in.

# HuggingFace token for pyannote models (accept the 5 model licenses first — see README).
HF_TOKEN=hf_your_token_here

# LM Studio OpenAI-compatible endpoint. Default assumes LM Studio on this machine.
LM_STUDIO_URL=http://127.0.0.1:1234/v1
LM_STUDIO_API_KEY=lm-studio
# Which model LM Studio should run for summaries/people-notes. Must be loaded
# (or auto-loadable) in LM Studio. Examples: local-model, google/gemma-4-26b-a4b
LM_STUDIO_MODEL=local-model

# Obsidian vault root. AuraScribe writes under <vault>\AuraScribe\.
# Example: C:\Users\you\Documents\Obsidian
OBSIDIAN_VAULT=C:\Users\%USERNAME%\Documents\Obsidian

# Python sidecar bind address. Localhost-only — the Tauri shell is the only caller.
SIDECAR_HOST=127.0.0.1
SIDECAR_PORT=8765

# ASR (faster-whisper). Model options: large-v3 | large-v3-turbo | distil-large-v3
WHISPER_MODEL=large-v3-turbo
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16
